{
  "name": "KSC Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "args": {
      "TZ": "${localEnv:TZ:America/Los_Angeles}",
      "ZSH_IN_DOCKER_VERSION": "1.2.1",
    },
  },
  // Project-specific environment variables (refreshed on each restart)
  "remoteEnv": {
    "SOME_SECRET_ENV_TOKEN": "${localEnv:SOME_SECRET_ENV_TOKEN}",
    // Keep this if you run Postgres using Docker and want to connect to it.
    "DATABASE_HOST": "host.docker.internal",
  },
  // Add any ports that you want to forward from the devcontainer to localhost here.
  // Currently adds the Phoenix (4000) and Tidewave (9832) ports but maps Tidewave to `localhost:9833` (not 9832)
  // to avoid clashes with your local Tidewave installation.
  "runArgs": ["--cap-add=NET_ADMIN", "--cap-add=NET_RAW", "--cap-add=SYS_ADMIN", "-p", "4000:4000", "-p", "9833:9832"],
  // Default configuration (baked in at container creation)
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/dev/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "false",
  },
  "remoteUser": "dev",
  "mounts": [
    "source=${localWorkspaceFolder}/.claude,target=/home/dev/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.gitconfig,target=/home/dev/.gitconfig,type=bind,consistency=cached",
  ],
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postStartCommand": "sudo /usr/local/bin/init-firewall.sh && sudo bash /workspace/.devcontainer/setup/init-file-protection.sh",
  "waitFor": "postStartCommand",
}
